<UserControl x:Class="ScheduleApp.UI.Views.UserFormView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<Grid Background="White">

		<TextBlock Text="{Binding FormTitle}"
                   FontSize="30"
                   FontWeight="Bold"
                   Foreground="Black"
                   Margin="25,25,0,0"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Top"/>

		<Border Margin="0,95,0,0"
                Height="430"
                Width="911"
                MaxWidth="1080"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                BorderBrush="#B8C0CC"
                BorderThickness="1"
                CornerRadius="28"
                Background="White">

			<Grid Margin="30,0,30,0">

				<TextBlock Text="Información usuario"
                           FontSize="26"
                           FontWeight="Bold"
                           Foreground="#0B132A"
                           Margin="0,18,0,0"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Top"/>

				<StackPanel Margin="0,85,0,0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Width="260">

					<TextBlock FontSize="17" FontWeight="Bold">
                        <Run Text="Nombre completo"/>
                        <Run Text="*" Foreground="Red"/>
					</TextBlock>

					<TextBox Height="38"
                             FontSize="16"
                             Margin="0,8,0,16"
                             Padding="8,0"
                             VerticalContentAlignment="Center"
                             Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}"/>

					<TextBlock FontSize="17" FontWeight="Bold">
                        <Run Text="Usuario"/>
                        <Run Text="*" Foreground="Red"/>
					</TextBlock>

					<TextBox Height="38"
                             FontSize="16"
                             Margin="0,8,0,16"
                             Padding="8,0"
                             VerticalContentAlignment="Center"
                             Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"/>

					<TextBlock FontSize="17" FontWeight="Bold">
                        <Run Text="Documento de identidad"/>
                        <Run Text="*" Foreground="Red"/>
					</TextBlock>

					<TextBox Height="38"
                             FontSize="16"
                             Margin="0,8,0,0"
                             Padding="8,0"
                             VerticalContentAlignment="Center"
                             Text="{Binding IdentityDocument, UpdateSourceTrigger=PropertyChanged}"/>
				</StackPanel>

				<StackPanel Margin="340,85,0,0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Width="280">

					<TextBlock FontSize="17" FontWeight="Bold">
                        <Run Text="Correo"/>
                        <Run Text="*" Foreground="Red"/>
					</TextBlock>

					<TextBox Height="38"
                             FontSize="16"
                             Margin="0,8,0,16"
                             Padding="8,0"
                             VerticalContentAlignment="Center"
                             Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"/>

					<TextBlock FontSize="17" FontWeight="Bold">
                        <Run Text="Contraseña"/>
                        <Run Text="*" Foreground="Red"/>
					</TextBlock>

					<PasswordBox x:Name="PasswordBox"
                                 Height="38"
                                 FontSize="16"
                                 Margin="0,8,0,16"
                                 Padding="8,0"
                                 VerticalContentAlignment="Center"
                                 PasswordChanged="PasswordBox_PasswordChanged"/>

					<TextBlock FontSize="17" FontWeight="Bold">
                        <Run Text="Confirmar contraseña"/>
                        <Run Text="*" Foreground="Red"/>
					</TextBlock>

					<PasswordBox x:Name="ConfirmPasswordBox"
                                 Height="38"
                                 FontSize="16"
                                 Margin="0,8,0,0"
                                 Padding="8,0"
                                 VerticalContentAlignment="Center"
                                 PasswordChanged="ConfirmPasswordBox_PasswordChanged"/>
				</StackPanel>

				<StackPanel Margin="625,85,0,0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Width="194">

					<TextBlock FontSize="17" FontWeight="Bold"
                               Height="27"
                               Width="124">
                        <Run Text="Rol"/>
                        <Run Text="*" Foreground="Red"/>
					</TextBlock>

					<ComboBox Height="38"
                              FontSize="16"
                              Margin="0,8,0,28"
                              Padding="8,0"
                              Width="131"
                              SelectedValue="{Binding SelectedRole, UpdateSourceTrigger=PropertyChanged}"
                              SelectedValuePath="Content">
						<ComboBoxItem Content="Administrador"/>
						<ComboBoxItem Content="Coordinador"/>
					</ComboBox>

					<TextBlock FontSize="17" FontWeight="Bold"
                               Width="110"
                               Height="25">
                        <Run Text="Estado"/>
                        <Run Text="*" Foreground="Red"/>
					</TextBlock>

					<ComboBox Height="38"
                              FontSize="16"
                              Margin="0,8,0,0"
                              Padding="8,0"
                              Width="119"
                              SelectedValue="{Binding SelectedStatus, UpdateSourceTrigger=PropertyChanged}"
                              SelectedValuePath="Content">
						<ComboBoxItem Content="Activo"/>
						<ComboBoxItem Content="Inactivo"/>
					</ComboBox>
				</StackPanel>

				<TextBlock Text="{Binding ErrorMessage}"
                           Foreground="Red"
                           FontSize="14"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Bottom"
                           Width="600"
                           Margin="0,0,0,78"/>

				<Button Content="Cancelar"
                        Height="44"
                        FontSize="18"
                        Background="White"
                        Foreground="Black"
                        BorderBrush="Black"
                        BorderThickness="1"
                        VerticalAlignment="Bottom"
                        Margin="40,0,602,22"
                        Cursor="Hand"
                        Command="{Binding CancelCommand}"/>

				<Button Content="Guardar"
                        Width="202"
                        Height="44"
                        FontSize="18"
                        FontWeight="Bold"
                        Background="#2E7D32"
                        Foreground="White"
                        BorderThickness="1.5"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Margin="0,0,202,22"
                        Cursor="Hand"
                        Command="{Binding SaveCommand}"/>

			</Grid>
		</Border>
	</Grid>
</UserControl>