<UserControl x:Class="ScheduleApp.UI.Views.DocentesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="750"
             d:DesignWidth="1200">

    <UserControl.Resources>

        <Style x:Key="ComboBoxPlaceholderStyle" TargetType="ComboBox">

            <Setter Property="Template">

                <Setter.Value>

                    <ControlTemplate TargetType="ComboBox">

                        <Grid>

                            <ToggleButton Background="White"
                                          BorderBrush="#A6A6A6"
                                          BorderThickness="1"
                                          HorizontalContentAlignment="Stretch"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">

                                <Grid>

                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <ContentPresenter Grid.Column="0"
                                                      Margin="10,0,0,0"
                                                      VerticalAlignment="Center"/>

                                    <TextBlock Grid.Column="1"
                                               Text="▼"
                                               Margin="0,0,10,0"
                                               VerticalAlignment="Center"
                                               Foreground="Gray"/>

                                </Grid>

                            </ToggleButton>

                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   Width="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                   AllowsTransparency="True">

                                <Border Background="White"
                                        BorderBrush="#A6A6A6"
                                        BorderThickness="1">

                                    <ItemsPresenter/>

                                </Border>

                            </Popup>

                            <TextBlock Text="{TemplateBinding Tag}"
                                       Foreground="Gray"
                                       Margin="12,0,0,0"
                                       VerticalAlignment="Center"
                                       IsHitTestVisible="False">

                                <TextBlock.Style>

                                    <Style TargetType="TextBlock">

                                        <Setter Property="Visibility"
                                                Value="Collapsed"/>

                                        <Style.Triggers>

                                            <DataTrigger Binding="{Binding SelectedItem, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                         Value="{x:Null}">

                                                <Setter Property="Visibility"
                                                        Value="Visible"/>

                                            </DataTrigger>

                                        </Style.Triggers>

                                    </Style>

                                </TextBlock.Style>

                            </TextBlock>

                        </Grid>

                    </ControlTemplate>

                </Setter.Value>

            </Setter>

        </Style>

        <Style TargetType="DataGridColumnHeader">

            <Setter Property="Background"
                    Value="#D9D9D9"/>

            <Setter Property="Foreground"
                    Value="#4A4A4A"/>

            <Setter Property="FontWeight"
                    Value="SemiBold"/>

            <Setter Property="FontSize"
                    Value="16"/>

            <Setter Property="Height"
                    Value="50"/>

            <Setter Property="HorizontalContentAlignment"
                    Value="Center"/>

            <Setter Property="BorderBrush"
                    Value="#A6A6A6"/>

            <Setter Property="BorderThickness"
                    Value="0.5"/>

        </Style>

        <!-- CELDAS -->
        <Style TargetType="DataGridCell">

            <Setter Property="HorizontalContentAlignment"
                    Value="Center"/>

            <Setter Property="VerticalContentAlignment"
                    Value="Center"/>

            <Setter Property="VerticalAlignment"
                    Value="Stretch"/>

            <Setter Property="Padding"
                    Value="0"/>

        </Style>

    </UserControl.Resources>

    <Grid Background="White">

        <!-- FONDO -->
        <Image Source="pack://application:,,,/Assets/ImagenFondo.jpeg"
               Opacity="0.12"
               Stretch="Uniform"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"/>

        <!-- TITULO -->
        <TextBlock Text="Docentes"
                   FontFamily="Segoe UI"
                   FontSize="34"
                   FontWeight="Bold"
                   Foreground="Black"
                   Margin="25,25,0,25"/>

        <!-- TRES PUNTOS -->
        <Grid HorizontalAlignment="Right"
      VerticalAlignment="Top"
      Margin="0,25,25,0">

            <StackPanel>

                <!-- BOTON -->
                <ToggleButton x:Name="OptionsButton"
                      Width="55"
                      Height="40"
                      Background="#F5F5F5"
                      BorderBrush="#E1D1B0"
                      BorderThickness="1.5"
                      Cursor="Hand">

                    <ToggleButton.Template>

                        <ControlTemplate TargetType="ToggleButton">

                            <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">

                                <TextBlock Text="⋮"
                                   FontSize="24"
                                   Foreground="#1B2A41"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>

                            </Border>

                        </ControlTemplate>

                    </ToggleButton.Template>

                </ToggleButton>

                <!-- TEXTO -->
                <TextBlock Text="Más opciones"
                   FontSize="12"
                   HorizontalAlignment="Center"
                   Margin="0,5,0,0"/>

            </StackPanel>

            <!-- POPUP -->
            <Popup IsOpen="{Binding IsChecked, ElementName=OptionsButton}"
           Placement="Bottom"
           PlacementTarget="{Binding ElementName=OptionsButton}"
           StaysOpen="False"
           AllowsTransparency="True">

                <Border Width="120"
                Background="White"
                BorderBrush="#D9D9D9"
                BorderThickness="2"
                Padding="10">

                    <StackPanel>

                        <!-- EXCEL -->
                        <Button Background="Transparent"
                        BorderThickness="0"
                        HorizontalContentAlignment="Left"
                        Cursor="Hand"
                        Margin="0,5">

                            <StackPanel Orientation="Horizontal">

                                <TextBlock Text="📗"
                                   FontSize="22"
                                   Margin="0,0,8,0"/>

                                <TextBlock Text="EXCEL"
                                   FontSize="16"
                                   VerticalAlignment="Center"/>

                            </StackPanel>

                        </Button>

                        <!-- PDF -->
                        <Button Background="Transparent"
                        BorderThickness="0"
                        HorizontalContentAlignment="Left"
                        Cursor="Hand"
                        Margin="0,10,0,0">

                            <StackPanel Orientation="Horizontal">

                                <TextBlock Text="📄"
                                   FontSize="22"
                                   Margin="0,0,8,0"
                                   Foreground="Red"/>

                                <TextBlock Text="PDF"
                                   FontSize="16"
                                   VerticalAlignment="Center"/>

                            </StackPanel>

                        </Button>

                    </StackPanel>

                </Border>

            </Popup>

        </Grid>

        <!-- BUSCADOR -->
        <Border Width="465"
                Height="45"
                BorderBrush="Black"
                BorderThickness="1.5"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="25,95,0,0">

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="50"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="🔍"
                           FontSize="18"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"/>

                <Grid Grid.Column="1">

                    <TextBox x:Name="SearchTextBox"
                             BorderThickness="0"
                             FontSize="18"
                             VerticalContentAlignment="Center"
                             Background="Transparent"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Text="Buscar docentes"
                               FontSize="18"
                               Foreground="Gray"
                               Margin="5,0,0,0"
                               VerticalAlignment="Center"
                               IsHitTestVisible="False">

                        <TextBlock.Style>

                            <Style TargetType="TextBlock">

                                <Setter Property="Visibility"
                                        Value="Visible"/>

                                <Style.Triggers>

                                    <DataTrigger Binding="{Binding Text, ElementName=SearchTextBox}"
                                                 Value="">
                                        <Setter Property="Visibility"
                                                Value="Visible"/>
                                    </DataTrigger>

                                    <DataTrigger Binding="{Binding Text, ElementName=SearchTextBox}"
                                                 Value="{x:Null}">
                                        <Setter Property="Visibility"
                                                Value="Visible"/>
                                    </DataTrigger>

                                    <DataTrigger Binding="{Binding IsKeyboardFocused, ElementName=SearchTextBox}"
                                                 Value="True">
                                        <Setter Property="Visibility"
                                                Value="Collapsed"/>
                                    </DataTrigger>

                                </Style.Triggers>

                            </Style>

                        </TextBlock.Style>

                    </TextBlock>

                </Grid>

            </Grid>

        </Border>

        <!-- FILTROS -->
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Margin="25,165,0,0">

            <!-- ESPECIALIDAD -->
            <ComboBox Width="220"
                      Height="40"
                      FontSize="16"
                      VerticalContentAlignment="Center"
                      Padding="8,0,0,0"
                      BorderBrush="Black"
                      BorderThickness="1.5"
                      Margin="0,0,25,0"
                      SelectedIndex="0">

                <ComboBoxItem Content="Especialidad"/>
                <ComboBoxItem Content="Matemáticas"/>
                <ComboBoxItem Content="Programación"/>
                <ComboBoxItem Content="Bases de Datos"/>
                <ComboBoxItem Content="Redes"/>

            </ComboBox>

            <!-- ESTADO -->
            <ComboBox Width="220"
                      Height="40"
                      FontSize="16"
                      VerticalContentAlignment="Center"
                      Padding="8,0,0,0"
                      BorderBrush="Black"
                      BorderThickness="1.5"
                      SelectedIndex="0">

                <ComboBoxItem Content="Estado"/>
                <ComboBoxItem Content="Activo"/>
                <ComboBoxItem Content="Inactivo"/>

            </ComboBox>

        </StackPanel>

        <!-- TABLA -->
        <DataGrid x:Name="TeachersDataGrid"
                  ItemsSource="{Binding DocentesPaginados}"
                  Margin="20,240,20,120"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  HeadersVisibility="Column"
                  RowHeight="55"
                  FontSize="14"
                  Background="White"
                  BorderBrush="#A6A6A6"
                  BorderThickness="1"
                  GridLinesVisibility="All"
                  HorizontalGridLinesBrush="#A6A6A6"
                  VerticalGridLinesBrush="#A6A6A6"
                  HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Disabled">

            <DataGrid.RowStyle>

                <Style TargetType="DataGridRow">

                    <Setter Property="Height"
                            Value="55"/>

                    <Setter Property="VerticalAlignment"
                            Value="Center"/>

                    <Setter Property="VerticalContentAlignment"
                            Value="Center"/>

                </Style>

            </DataGrid.RowStyle>

            <DataGrid.Columns>

                <!-- DOCUMENTO -->
                <DataGridTextColumn Header="Documento"
                                    Width="*"
                                    Binding="{Binding Document}"/>

                <!-- NOMBRE -->
                <DataGridTextColumn Header="Nombre"
                                    Width="1.5*"
                                    Binding="{Binding FullName}"/>

                <!-- CORREO -->
                <DataGridTextColumn Header="Correo"
                                    Width="2*"
                                    Binding="{Binding Email}"/>

                <!-- ESTADO -->
                <DataGridTemplateColumn Header="Estado"
                                        Width="*">

                    <DataGridTemplateColumn.CellTemplate>

                        <DataTemplate>

                            <Border HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch">

                                <Border.Style>

                                    <Style TargetType="Border">

                                        <Setter Property="Background"
                                                Value="#E53935"/>

                                        <Style.Triggers>

                                            <DataTrigger Binding="{Binding Status}"
                                                         Value="Activo">

                                                <Setter Property="Background"
                                                        Value="#2E7D32"/>

                                            </DataTrigger>

                                            <DataTrigger Binding="{Binding Status}"
                                                         Value="Inactivo">

                                                <Setter Property="Background"
                                                        Value="#E53935"/>

                                            </DataTrigger>

                                        </Style.Triggers>

                                    </Style>

                                </Border.Style>

                                <TextBlock Text="{Binding Status}"
                                           Foreground="White"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>

                            </Border>

                        </DataTemplate>

                    </DataGridTemplateColumn.CellTemplate>

                </DataGridTemplateColumn>

                <!-- ACCIONES -->
                <DataGridTemplateColumn Header="Acciones"
                                        Width="1.5*">

                    <DataGridTemplateColumn.CellTemplate>

                        <DataTemplate>

                            <Grid Height="55"
                                  Background="White">

                                <Border BorderBrush="#A6A6A6"
                                        BorderThickness="0.5"
                                        Margin="-1">

                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center">

                                        <!-- VER -->
                                        <Button Width="32"
                                                Height="32"
                                                Margin="2"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                FontSize="16"
                                                Cursor="Hand"
                                                ToolTip="Ver docente"
                                                Content="👁"/>

                                        <!-- EDITAR -->
                                        <Button Width="32"
                                                Height="32"
                                                Margin="2"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                FontSize="16"
                                                Cursor="Hand"
                                                Foreground="#2F6FED"
                                                ToolTip="Editar docente"
                                                Content="✎"/>

                                        <!-- ELIMINAR -->
                                        <Button Width="32"
                                                Height="32"
                                                Margin="2"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                FontSize="16"
                                                Cursor="Hand"
                                                Foreground="#E53935"
                                                ToolTip="Eliminar docente"
                                                Content="🗑"/>

                                    </StackPanel>

                                </Border>

                            </Grid>

                        </DataTemplate>

                    </DataGridTemplateColumn.CellTemplate>

                </DataGridTemplateColumn>

            </DataGrid.Columns>

        </DataGrid>

        <!-- PAGINACION -->
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Bottom"
                    Margin="25,0,0,28">

            <Button Content="≪"
                    Width="40"
                    Height="35"
                    FontSize="22"
                    Background="Transparent"
                    BorderThickness="0"
                    Cursor="Hand"
                    Command="{Binding PreviousPageCommand}"/>

            <Border Width="40"
                    Height="35"
                    Background="#1B2A41"
                    Margin="10,0,10,0">

                <TextBlock Text="{Binding CurrentPage}"
                           Foreground="White"
                           FontSize="18"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>

            </Border>

            <Button Content="≫"
                    Width="40"
                    Height="35"
                    FontSize="22"
                    Background="Transparent"
                    BorderThickness="0"
                    Cursor="Hand"
                    Command="{Binding NextPageCommand}"/>

            <TextBlock Text="{Binding TotalPages, StringFormat= de {0}}"
                       FontSize="16"
                       VerticalAlignment="Center"
                       Margin="8,0,0,0"/>

        </StackPanel>

        <!-- BOTON -->
        <Button Content="+ Nuevo docente"
                Width="220"
                Height="50"
                FontSize="18"
                Background="#1B2A41"
                Foreground="White"
                BorderThickness="0"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Margin="0,0,25,25">

            <Button.Template>

                <ControlTemplate TargetType="Button">

                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="12">

                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>

                    </Border>

                </ControlTemplate>

            </Button.Template>

        </Button>

    </Grid>

</UserControl>