<UserControl x:Class="ScheduleApp.UI.Views.UsuariosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="750"
             d:DesignWidth="1200">

    <UserControl.Resources>
        <Style x:Key="ComboBoxPlaceholderStyle" TargetType="ComboBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Background="White"
                                          BorderBrush="#A6A6A6"
                                          BorderThickness="1"
                                          HorizontalContentAlignment="Stretch"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter Grid.Column="0" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="▼" Margin="0,0,10,0" VerticalAlignment="Center" Foreground="Gray"/>
                                </Grid>
                            </ToggleButton>

                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   Width="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                   AllowsTransparency="True">
                                <Border Background="White" BorderBrush="#A6A6A6" BorderThickness="1">
                                    <ItemsPresenter/>
                                </Border>
                            </Popup>

                            <TextBlock Text="{TemplateBinding Tag}" Foreground="Gray" Margin="12,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedItem, RelativeSource={RelativeSource AncestorType=ComboBox}}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#D9D9D9"/>
            <Setter Property="Foreground" Value="#4A4A4A"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#A6A6A6"/>
            <Setter Property="BorderThickness" Value="0.5"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="White">
        <Image Source="pack://application:,,,/Assets/ImagenFondo.jpeg" Opacity="0.12" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>

        <TextBlock Text="Usuarios" FontFamily="Segoe UI" FontSize="34" FontWeight="Bold" Foreground="Black" Margin="25,25,0,25"/>

        <Border Width="465" Height="45" BorderBrush="Black" BorderThickness="1.5" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="25,95,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="50"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="🔍" FontSize="18" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                <Grid Grid.Column="1">

                    <TextBox x:Name="SearchTextBox"
                             BorderThickness="0"
                             FontSize="18"
                             VerticalContentAlignment="Center"
                             Background="Transparent"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Text="Buscar usuario"
                               FontSize="18"
                               Foreground="Gray"
                               Margin="5,0,0,0"
                               VerticalAlignment="Center"
                               IsHitTestVisible="False">

                        <TextBlock.Style>
                            <Style TargetType="TextBlock">

                                <Setter Property="Visibility" Value="Visible"/>

                                <Style.Triggers>

                                    <DataTrigger Binding="{Binding Text, ElementName=SearchTextBox}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>

                                    <DataTrigger Binding="{Binding Text, ElementName=SearchTextBox}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>

                                    <DataTrigger Binding="{Binding IsKeyboardFocused, ElementName=SearchTextBox}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>

                                </Style.Triggers>

                            </Style>
                        </TextBlock.Style>

                    </TextBlock>

                </Grid>
            </Grid>
        </Border>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="25,165,0,0">
            <ComboBox Width="220" Height="40" FontSize="16" VerticalContentAlignment="Center" Padding="8,0,0,0" BorderBrush="Black" BorderThickness="1.5" Margin="0,0,25,0" SelectedIndex="0" SelectedValuePath="Content"
                      SelectedValue="{Binding SelectedStatus, UpdateSourceTrigger=PropertyChanged}">
                <ComboBoxItem Content="Estado"/>
                <ComboBoxItem Content="Activo"/>
                <ComboBoxItem Content="Inactivo"/>
            </ComboBox>

            <ComboBox Width="220" Height="40" FontSize="16" VerticalContentAlignment="Center" Padding="8,0,0,0" BorderBrush="Black" BorderThickness="1.5" SelectedIndex="0" SelectedValuePath="Content"
                      SelectedValue="{Binding SelectedRole, UpdateSourceTrigger=PropertyChanged}">
                <ComboBoxItem Content="Rol"/>
                <ComboBoxItem Content="Administrador"/>
                <ComboBoxItem Content="Coordinador"/>
            </ComboBox>
        </StackPanel>

        <DataGrid x:Name="UsersDataGrid"
                  ItemsSource="{Binding UsuariosPaginados}"
                  Margin="20,240,20,120"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  HeadersVisibility="Column"
                  RowHeight="55"
                  FontSize="14"
                  Background="White"
                  BorderBrush="#A6A6A6"
                  BorderThickness="1"
                  GridLinesVisibility="All"
                  HorizontalGridLinesBrush="#A6A6A6"
                  VerticalGridLinesBrush="#A6A6A6"
                  HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Disabled">

            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="Height" Value="55"/>
                    <Setter Property="VerticalAlignment" Value="Center"/>
                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                </Style>
            </DataGrid.RowStyle>

            <DataGrid.Columns>
                <DataGridTextColumn Header="Usuario" Width="*" Binding="{Binding Username}"/>
                <DataGridTextColumn Header="Nombre Completo" Width="2*" Binding="{Binding FullName}"/>
                <DataGridTextColumn Header="Correo" Width="2*" Binding="{Binding Email}"/>

                <DataGridTemplateColumn Header="Estado" Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#E53935"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Status}" Value="Activo">
                                                <Setter Property="Background" Value="#2E7D32"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Status}" Value="Inactivo">
                                                <Setter Property="Background" Value="#E53935"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding Status}" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="Rol" Width="*" Binding="{Binding Role}"/>

                <DataGridTemplateColumn Header="Acciones" Width="1.5*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Grid Height="55" Background="White">
                                <Border BorderBrush="#A6A6A6" BorderThickness="0.5" Margin="-1">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Button Width="32" Height="32" Margin="2" Background="Transparent" BorderThickness="0" FontSize="16" Cursor="Hand" ToolTip="Ver usuario" Content="👁"
                                                Command="{Binding DataContext.ShowUserDetailCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"/>
                                        <Button Width="32" Height="32" Margin="2" Background="Transparent" BorderThickness="0" FontSize="16" Cursor="Hand" ToolTip="Editar usuario" Foreground="#2F6FED" Content="✎"
                                                Command="{Binding DataContext.ShowEditUserFormCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"/>
                                        <Button Width="32" Height="32" Margin="2" Background="Transparent" BorderThickness="0" FontSize="16" Cursor="Hand" ToolTip="Eliminar usuario" Foreground="#E53935" Content="🗑"
                                                Command="{Binding DataContext.ShowDeleteUserCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="25,0,0,28">
            <Button Content="≪" Width="40" Height="35" FontSize="22" Background="Transparent" BorderThickness="0" Cursor="Hand" Command="{Binding PreviousPageCommand}"/>
            <Border Width="40" Height="35" Background="#1B2A41" Margin="10,0,10,0">
                <TextBlock Text="{Binding CurrentPage}" Foreground="White" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <Button Content="≫" Width="40" Height="35" FontSize="22" Background="Transparent" BorderThickness="0" Cursor="Hand" Command="{Binding NextPageCommand}"/>
            <TextBlock Text="{Binding TotalPages, StringFormat= de {0}}" FontSize="16" VerticalAlignment="Center" Margin="8,0,0,0"/>
        </StackPanel>

        <Button Content="+ Nuevo usuario"
                Width="220" Height="50" FontSize="18" Background="#1B2A41" Foreground="White" BorderThickness="0"
                HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,25,25"
                Command="{Binding DataContext.ShowUserFormCommand, RelativeSource={RelativeSource AncestorType=Window}}">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" CornerRadius="12">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Button.Template>
        </Button>
    </Grid>
</UserControl>