<UserControl x:Class="ScheduleApp.UI.Views.UsuariosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="750"
             d:DesignWidth="1200">

    <UserControl.Resources>

        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="44"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Background" Value="#1B2A41"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#1B2A41"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

    </UserControl.Resources>

    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- MENU IZQUIERDO -->
        <Grid Grid.Column="0" Background="#1B2A41">

            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <ScrollViewer Grid.Row="0"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">

                <StackPanel Margin="25,10,25,20">

                    <Image Source="pack://application:,,,/Assets/Logo.jpeg"
                           Height="150"
                           Stretch="Uniform"
                           Margin="0,0,0,10"/>

                    <StackPanel HorizontalAlignment="Center"
                                Margin="0,0,0,20">

                        <Image Source="{Binding ImagenRol}"
                               Width="40"
                               Height="40"
                               Stretch="Uniform"
                               Margin="0,0,0,5"/>

                        <TextBlock Text="{Binding RolUsuario}"
                                   HorizontalAlignment="Center"
                                   Foreground="White"
                                   FontSize="14"
                                   FontWeight="Bold"/>
                    </StackPanel>

                    <!-- INICIO -->
                    <Button Command="{Binding ShowDashboardCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource MenuButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ModuloActivo}" Value="Inicio">
                                        <Setter Property="Background" Value="#D4B36A"/>
                                        <Setter Property="BorderBrush" Value="#D4B36A"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>

                        <Grid Width="210">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Image Source="pack://application:,,,/Assets/Inicio.png"
                                   Width="30"
                                   Height="30"/>

                            <TextBlock Grid.Column="1"
                                       Text="Inicio"
                                       Foreground="White"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Button>

                    <!-- MATERIAS -->
                    <Button Command="{Binding ShowMateriasCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource MenuButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ModuloActivo}" Value="Materias">
                                        <Setter Property="Background" Value="#D4B36A"/>
                                        <Setter Property="BorderBrush" Value="#D4B36A"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>

                        <Grid Width="210">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Image Source="pack://application:,,,/Assets/Materias.png"
                                   Width="30"
                                   Height="30"/>

                            <TextBlock Grid.Column="1"
                                       Text="Materias"
                                       Foreground="White"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Button>

                    <!-- PROGRAMAS -->
                    <Button Style="{StaticResource MenuButtonStyle}">
                        <Grid Width="210">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Image Source="pack://application:,,,/Assets/Programas.png"
                                   Width="30"
                                   Height="30"/>

                            <TextBlock Grid.Column="1"
                                       Text="Programas"
                                       Foreground="White"/>
                        </Grid>
                    </Button>

                    <!-- DOCENTES -->
                    <Button Style="{StaticResource MenuButtonStyle}">
                        <Grid Width="210">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Image Source="pack://application:,,,/Assets/Docentes.png"
                                   Width="30"
                                   Height="30"/>

                            <TextBlock Grid.Column="1"
                                       Text="Docentes"
                                       Foreground="White"/>
                        </Grid>
                    </Button>

                    <!-- AULAS -->
                    <Button Style="{StaticResource MenuButtonStyle}">
                        <Grid Width="210">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Image Source="pack://application:,,,/Assets/Aulas.png"
                                   Width="30"
                                   Height="30"/>

                            <TextBlock Grid.Column="1"
                                       Text="Aulas"
                                       Foreground="White"/>
                        </Grid>
                    </Button>

                    <!-- HORARIOS -->
                    <Button Style="{StaticResource MenuButtonStyle}">
                        <Grid Width="210">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Image Source="pack://application:,,,/Assets/Horarios.png"
                                   Width="30"
                                   Height="30"/>

                            <TextBlock Grid.Column="1"
                                       Text="Horarios"
                                       Foreground="White"/>
                        </Grid>
                    </Button>

                    <!-- RESTRICCIONES -->
                    <Button Style="{StaticResource MenuButtonStyle}">
                        <Grid Width="210">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Image Source="pack://application:,,,/Assets/Restricciones.png"
                                   Width="30"
                                   Height="30"/>

                            <TextBlock Grid.Column="1"
                                       Text="Restricciones"
                                       Foreground="White"/>
                        </Grid>
                    </Button>

                    <!-- USUARIOS -->
                    <Button Style="{StaticResource MenuButtonStyle}"
                            Visibility="{Binding EsAdministrador, Converter={StaticResource BoolToVisibilityConverter}}">

                        <Grid Width="210">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Image Source="pack://application:,,,/Assets/Usuarios.png"
                                   Width="30"
                                   Height="30"/>

                            <TextBlock Grid.Column="1"
                                       Text="Usuarios"
                                       Foreground="White"/>

                        </Grid>

                    </Button>

                    <!-- MANUAL -->
                    <Button Style="{StaticResource MenuButtonStyle}"
                            Visibility="{Binding EsAdministrador, Converter={StaticResource BoolToVisibilityConverter}}">

                        <Grid Width="210">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Image Source="pack://application:,,,/Assets/ManualUsuario.png"
                                   Width="30"
                                   Height="30"/>

                            <TextBlock Grid.Column="1"
                                       Text="Manual del sistema"
                                       Foreground="White"/>

                        </Grid>

                    </Button>

                </StackPanel>

            </ScrollViewer>

            <!-- CERRAR SESIÓN -->
            <Button Grid.Row="1"
                    Height="42"
                    Width="190"
                    Margin="0,10,0,25"
                    HorizontalAlignment="Center"
                    Background="#1B2A41"
                    Foreground="White"
                    BorderBrush="#D4B36A"
                    BorderThickness="1.5"
                    HorizontalContentAlignment="Stretch"
                    Padding="0"
                    Command="{Binding ShowLogoutCommand}">

                <Grid>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="55"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Image Source="pack://application:,,,/Assets/CerrarSesion.png"
                           Width="26"
                           Height="26"
                           Stretch="Uniform"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>

                    <TextBlock Grid.Column="1"
                               Text="Cerrar sesión"
                               Foreground="White"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Left"/>

                </Grid>

            </Button>

        </Grid>

        <!-- CONTENIDO -->
        <Grid Grid.Column="1"
              Background="White">

            <Image Source="pack://application:,,,/Assets/ImagenFondo.jpeg"
                   Opacity="0.12"
                   Stretch="Uniform"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"/>

            <ContentControl Content="{Binding CurrentView}"
                            Background="Transparent"/>

            <!-- TÍTULO -->
            <TextBlock Text="Usuarios"
                       FontFamily="Segoe UI"
                       FontSize="34"
                       FontWeight="Bold"
                       Foreground="Black"
                       Margin="25,25,0,25"/>

            <!-- BUSCADOR -->
            <Border Width="450"
                    Height="45"
                    BorderBrush="Black"
                    BorderThickness="1.5"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Margin="25,95,0,0">

                <Grid>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="50"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="🔍"
                               FontSize="18"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"/>

                    <TextBox Grid.Column="1"
                             BorderThickness="0"
                             FontSize="18"
                             VerticalContentAlignment="Center"
                             Text="Buscar usuario"/>

                </Grid>

            </Border>

            <!-- FILTROS -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Margin="25,165,0,0">

                <!-- ESTADO -->
                <ComboBox Width="220"
                          Height="45"
                          FontSize="16"
                          Margin="0,0,25,0">

                    <ComboBoxItem Content="Estado"/>
                    <ComboBoxItem Content="Activo"/>
                    <ComboBoxItem Content="Inactivo"/>

                </ComboBox>

                <!-- ROL -->
                <ComboBox Width="220"
                          Height="45"
                          FontSize="16">

                    <ComboBoxItem Content="Rol"/>
                    <ComboBoxItem Content="Administrador"/>
                    <ComboBoxItem Content="Coordinador"/>

                </ComboBox>

            </StackPanel>

        </Grid>

    </Grid>

</UserControl>