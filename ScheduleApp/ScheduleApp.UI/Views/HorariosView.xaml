<UserControl x:Class="ScheduleApp.UI.Views.HorariosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ScheduleApp.UI.Views"
             mc:Ignorable="d" 
             d:DesignHeight="750" d:DesignWidth="1100">

    <Grid Background="White" Margin="30,20,30,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Horarios" 
                       FontFamily="Segoe UI" 
                       FontSize="36" 
                       FontWeight="Bold" 
                       Foreground="Black" 
                       Margin="0,0,0,25"/>

            <WrapPanel Orientation="Horizontal">

                <StackPanel Orientation="Horizontal" Margin="0,0,35,15" VerticalAlignment="Center">
                    <TextBlock Text="Programa:" FontWeight="Bold" FontSize="18" Foreground="Black" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <ComboBox Width="250" Height="40" FontSize="16" VerticalContentAlignment="Center" Padding="8,0,0,0" BorderBrush="Black" BorderThickness="1.5" SelectedIndex="0">
                        <ComboBoxItem Content="Ingeniería de sistemas"/>
                        <ComboBoxItem Content="Administración de empresas"/>
                    </ComboBox>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,0,35,15" VerticalAlignment="Center">
                    <TextBlock Text="Jornada:" FontWeight="Bold" FontSize="18" Foreground="Black" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <ComboBox Width="140" Height="40" FontSize="16" VerticalContentAlignment="Center" Padding="8,0,0,0" BorderBrush="Black" BorderThickness="1.5" SelectedIndex="0">
                        <ComboBoxItem Content="Diurna"/>
                        <ComboBoxItem Content="Nocturna"/>
                    </ComboBox>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,0,35,15" VerticalAlignment="Center">
                    <TextBlock Text="Ver Más opciones:" FontWeight="Bold" FontSize="18" Foreground="Black" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <ComboBox Width="160" Height="40" FontSize="16" VerticalContentAlignment="Center" Padding="8,0,0,0" BorderBrush="Black" BorderThickness="1.5" SelectedIndex="0">
                        <ComboBoxItem Content="Opción 2"/>
                    </ComboBox>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,15" VerticalAlignment="Center">
                    <TextBlock Text="Semestre:" FontWeight="Bold" FontSize="18" Foreground="Black" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <ComboBox Width="90" Height="40" FontSize="16" VerticalContentAlignment="Center" Padding="8,0,0,0" BorderBrush="Black" BorderThickness="1.5" SelectedIndex="0">
                        <ComboBoxItem Content="3"/>
                        <ComboBoxItem Content="4"/>
                        <ComboBoxItem Content="5"/>
                    </ComboBox>
                </StackPanel>

            </WrapPanel>
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,10,0,20">
        </Grid>

        <Grid Grid.Row="2" Margin="0,15,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" 
                    Content="Generar Horario" 
                    Width="240" Height="50" 
                    Background="#76828E" Foreground="White" 
                    FontSize="18" FontWeight="Bold" Cursor="Hand" BorderThickness="0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <Button Grid.Column="2" 
                    Content="Guardar Horario" 
                    Width="240" Height="50" 
                    Background="#2A7A39" Foreground="White" 
                    FontSize="18" FontWeight="Bold" Cursor="Hand" BorderThickness="0" Margin="0,0,20,0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <Button Grid.Column="3" 
                    Content="Editar" 
                    Width="160" Height="50" 
                    Background="#9EB14C" Foreground="White" 
                    FontSize="18" FontWeight="Bold" Cursor="Hand" BorderThickness="0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>

    </Grid>
</UserControl>