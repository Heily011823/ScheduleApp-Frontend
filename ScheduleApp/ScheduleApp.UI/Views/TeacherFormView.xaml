<UserControl x:Class="ScheduleApp.UI.Views.TeacherFormView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="#F5F5F5"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch">

    <Grid>

        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">

            <Grid Margin="30">

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- HEADER -->
                <Grid Grid.Row="0">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Nuevo Docente"
                               FontSize="30"
                               FontWeight="Bold"
                               Foreground="Black"
                               VerticalAlignment="Center"/>

                    <!-- MÁS OPCIONES -->
                    <StackPanel Grid.Column="1"
                                HorizontalAlignment="Center">

                        <Button Width="25"
                                Height="25"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand">

                            <StackPanel>
                                <Ellipse Width="4"
                                         Height="4"
                                         Fill="#333"
                                         Margin="0,1"/>

                                <Ellipse Width="4"
                                         Height="4"
                                         Fill="#333"
                                         Margin="0,1"/>

                                <Ellipse Width="4"
                                         Height="4"
                                         Fill="#333"
                                         Margin="0,1"/>
                            </StackPanel>

                        </Button>

                        <TextBlock Text="Más opciones"
                                   FontSize="10"
                                   HorizontalAlignment="Center"/>

                    </StackPanel>

                </Grid>

                <!-- STEPPER -->
                <Grid Grid.Row="1"
      Margin="0,30,0,30"
      ClipToBounds="False">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- PASO 1 -->
                    <StackPanel Grid.Column="0"
                Orientation="Horizontal"
                VerticalAlignment="Center"
                HorizontalAlignment="Left">

                        <Border x:Name="Step1Circle"
                Width="55"
                Height="55"
                Background="#6D7683"
                CornerRadius="28">

                            <TextBlock Text="1"
                       Foreground="White"
                       FontSize="18"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
                        </Border>

                        <TextBlock x:Name="Step1Text"
                   Text="Información Básica"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Foreground="#667085"
                   Margin="12,0,0,0"
                   VerticalAlignment="Center"/>

                    </StackPanel>

                    <!-- LINEA 1 -->
                    <Rectangle Grid.Column="1"
               Height="3"
               Fill="#9CA3AF"
               VerticalAlignment="Center"
               HorizontalAlignment="Stretch"
               Margin="10,0"/>

                    <!-- PASO 2 -->
                    <StackPanel Grid.Column="2"
                Orientation="Horizontal"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">

                        <Border x:Name="Step2Circle"
                Width="55"
                Height="55"
                BorderBrush="#9CA3AF"
                BorderThickness="1.5"
                Background="Transparent"
                CornerRadius="28">

                            <TextBlock Text="2"
                       Foreground="#6B7280"
                       FontSize="18"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
                        </Border>

                        <TextBlock x:Name="Step2Text"
                   Text="Especialidades y Materias"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Foreground="#667085"
                   Margin="12,0,0,0"
                   VerticalAlignment="Center"
                   Width="150"
                   TextWrapping="Wrap"/>

                    </StackPanel>

                    <!-- LINEA 2 -->
                    <Rectangle Grid.Column="3"
               Height="3"
               Fill="#9CA3AF"
               VerticalAlignment="Center"
               HorizontalAlignment="Stretch"
               Margin="10,0"/>

                    <!-- PASO 3 -->
                    <StackPanel Grid.Column="4"
                Orientation="Horizontal"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">

                        <Border x:Name="Step3Circle"
                Width="55"
                Height="55"
                BorderBrush="#9CA3AF"
                BorderThickness="1.5"
                Background="Transparent"
                CornerRadius="28">

                            <TextBlock Text="3"
                       Foreground="#6B7280"
                       FontSize="18"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
                        </Border>

                        <TextBlock x:Name="Step3Text"
                   Text="Disponibilidad Horaria"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Foreground="#667085"
                   Margin="12,0,0,0"
                   VerticalAlignment="Center"
                   Width="120"
                   TextWrapping="Wrap"/>

                    </StackPanel>

                </Grid>

                <!-- STEP 1 -->
                <Grid x:Name="Step1Grid"
                      Grid.Row="2">

                    <Border BorderBrush="#B0B0B0"
                            BorderThickness="1"
                            CornerRadius="20"
                            Padding="28"
                            Background="#F7F7F7">

                        <Grid>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- TITULO -->
                            <TextBlock Text="Información básica del docente"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="#1E293B"/>

                            <!-- FORMULARIO -->
                            <Grid Grid.Row="1"
                                  Margin="0,25,0,0">

                                <Grid.Resources>

                                    <Style TargetType="TextBox">
                                        <Setter Property="Height" Value="40"/>
                                        <Setter Property="FontSize" Value="14"/>
                                        <Setter Property="Padding" Value="10,0"/>
                                        <Setter Property="BorderBrush" Value="#A3A3A3"/>
                                        <Setter Property="BorderThickness" Value="1"/>
                                    </Style>

                                    <Style TargetType="ComboBox">
                                        <Setter Property="Height" Value="40"/>
                                        <Setter Property="FontSize" Value="14"/>
                                    </Style>

                                </Grid.Resources>

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- DOCUMENTO -->
                                <StackPanel Grid.Row="0"
                                            Grid.Column="0"
                                            Margin="0,0,25,18">

                                    <TextBlock FontSize="15"
                                               FontWeight="Bold">
                                        Documento de identidad
                                        <Run Foreground="Red">*</Run>
                                    </TextBlock>

                                    <TextBox/>

                                </StackPanel>

                                <!-- TELEFONO -->
                                <StackPanel Grid.Row="0"
                                            Grid.Column="1"
                                            Margin="0,0,25,18">

                                    <TextBlock FontSize="15"
                                               FontWeight="Bold">
                                        Teléfono
                                        <Run Foreground="Red">*</Run>
                                    </TextBlock>

                                    <TextBox/>

                                </StackPanel>

                                <!-- HORAS -->
                                <StackPanel Grid.Row="0"
                                            Grid.Column="2">

                                    <TextBlock FontSize="15"
                                               FontWeight="Bold">
                                        Cantidad de horas a dictar
                                        <Run Foreground="Red">*</Run>
                                    </TextBlock>

                                    <TextBox/>

                                </StackPanel>

                                <!-- NOMBRES -->
                                <StackPanel Grid.Row="1"
                                            Grid.Column="0"
                                            Margin="0,0,25,18">

                                    <TextBlock FontSize="15"
                                               FontWeight="Bold">
                                        Nombres
                                        <Run Foreground="Red">*</Run>
                                    </TextBlock>

                                    <TextBox/>

                                </StackPanel>

                                <!-- CORREO -->
                                <StackPanel Grid.Row="1"
                                            Grid.Column="1"
                                            Margin="0,0,25,18">

                                    <TextBlock FontSize="15"
                                               FontWeight="Bold">
                                        Correo
                                        <Run Foreground="Red">*</Run>
                                    </TextBlock>

                                    <TextBox/>

                                </StackPanel>

                                <!-- CONTRATO -->
                                <StackPanel Grid.Row="1"
                                            Grid.Column="2">

                                    <TextBlock FontSize="15"
                                               FontWeight="Bold">
                                        Tipo de contrato
                                        <Run Foreground="Red">*</Run>
                                    </TextBlock>

                                    <ComboBox SelectedIndex="0">

                                        <ComboBoxItem Content="Tiempo completo"/>
                                        <ComboBoxItem Content="Medio tiempo"/>

                                    </ComboBox>

                                </StackPanel>

                                <!-- APELLIDOS -->
                                <StackPanel Grid.Row="2"
                                            Grid.Column="0"
                                            Margin="0,0,25,0">

                                    <TextBlock FontSize="15"
                                               FontWeight="Bold">
                                        Apellidos
                                        <Run Foreground="Red">*</Run>
                                    </TextBlock>

                                    <TextBox/>

                                </StackPanel>

                                <!-- ESTADO -->
                                <StackPanel Grid.Row="2"
                                            Grid.Column="1"
                                            Margin="0,0,25,0">

                                    <TextBlock FontSize="15"
                                               FontWeight="Bold">
                                        Estado
                                        <Run Foreground="Red">*</Run>
                                    </TextBlock>

                                    <ComboBox SelectedIndex="0">

                                        <ComboBoxItem Content="Activo"/>
                                        <ComboBoxItem Content="Inactivo"/>

                                    </ComboBox>

                                </StackPanel>

                            </Grid>

                            <!-- FOOTER -->
                            <Grid Grid.Row="2"
                                  Margin="0,35,0,0">

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel>

                                    <TextBlock Text="Tiempo completo: Hasta 40 horas semanales"
                                               FontSize="13"
                                               Foreground="#7B8490"/>

                                    <TextBlock Text="Medio tiempo: Hasta 16 horas semanales"
                                               FontSize="13"
                                               Foreground="#7B8490"
                                               Margin="0,5,0,0"/>

                                </StackPanel>

                                <StackPanel Grid.Column="1"
                                            Orientation="Horizontal">

                                    <Button Content="Cancelar"
                                            Width="150"
                                            Height="45"
                                            FontSize="14"
                                            Margin="0,0,12,0"
                                            Background="White"
                                            BorderBrush="#444"
                                            BorderThickness="1"
                                            Cursor="Hand"/>

                                    <Button Width="170"
                                            Height="45"
                                            Background="#16253A"
                                            Foreground="White"
                                            FontSize="14"
                                            FontWeight="SemiBold"
                                            Cursor="Hand"
                                            BorderBrush="#0F172A"
                                            BorderThickness="1"
                                            Click="NextButton_Click">

                                        <StackPanel Orientation="Horizontal"
                                                    HorizontalAlignment="Center">

                                            <TextBlock Text="Siguiente"
                                                       Margin="0,0,8,0"/>

                                            <TextBlock Text="→"/>

                                        </StackPanel>

                                    </Button>

                                </StackPanel>

                            </Grid>

                        </Grid>

                    </Border>

                </Grid>

                <!-- STEP 2 -->
                <Grid x:Name="Step2Grid"
                      Grid.Row="2"
                      Visibility="Collapsed">

                    <Border BorderBrush="#B0B0B0"
                            BorderThickness="1"
                            CornerRadius="20"
                            Padding="28"
                            Background="#F7F7F7">

                        <Grid>

                            <TextBlock Text="SECCIÓN 2"
                                       FontSize="40"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>

                        </Grid>

                    </Border>

                </Grid>

            </Grid>

        </ScrollViewer>

    </Grid>

</UserControl>