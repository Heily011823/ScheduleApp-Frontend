<UserControl x:Class="ScheduleApp.UI.Views.TeacherFormView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="#F5F5F5"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch">

    <Grid>

        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">

            <Grid Margin="30">

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- HEADER -->
                <Grid Grid.Row="0">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Nuevo Docente"
                               FontSize="30"
                               FontWeight="Bold"
                               Foreground="Black"
                               VerticalAlignment="Center"/>

                    <StackPanel Grid.Column="1"
                                HorizontalAlignment="Center">

                        <Button Width="25"
                                Height="25"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand">

                            <StackPanel>

                                <Ellipse Width="4"
                                         Height="4"
                                         Fill="#333"
                                         Margin="0,1"/>

                                <Ellipse Width="4"
                                         Height="4"
                                         Fill="#333"
                                         Margin="0,1"/>

                                <Ellipse Width="4"
                                         Height="4"
                                         Fill="#333"
                                         Margin="0,1"/>

                            </StackPanel>

                        </Button>

                        <TextBlock Text="Más opciones"
                                   FontSize="10"
                                   HorizontalAlignment="Center"/>

                    </StackPanel>

                </Grid>

                <!-- STEPPER -->
                <Grid Grid.Row="1"
                      Margin="0,30,0,30">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- PASO 1 -->
                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal">

                        <Border x:Name="Step1Circle"
                                Width="55"
                                Height="55"
                                Background="#6D7683"
                                CornerRadius="28">

                            <TextBlock Text="1"
                                       Foreground="White"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>

                        </Border>

                        <TextBlock x:Name="Step1Text"
                                   Text="Información Básica"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#667085"
                                   Margin="12,0,0,0"
                                   VerticalAlignment="Center"/>

                    </StackPanel>

                    <!-- LINEA -->
                    <Rectangle Grid.Column="1"
                               Height="3"
                               Fill="#9CA3AF"
                               VerticalAlignment="Center"
                               Margin="10,0"/>

                    <!-- PASO 2 -->
                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal">

                        <Border x:Name="Step2Circle"
                                Width="55"
                                Height="55"
                                BorderBrush="#9CA3AF"
                                BorderThickness="1.5"
                                Background="Transparent"
                                CornerRadius="28">

                            <TextBlock Text="2"
                                       Foreground="#6B7280"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>

                        </Border>

                        <TextBlock x:Name="Step2Text"
                                   Text="Especialidades y Materias"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#667085"
                                   Width="150"
                                   Margin="12,0,0,0"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center"/>

                    </StackPanel>

                    <!-- LINEA -->
                    <Rectangle Grid.Column="3"
                               Height="3"
                               Fill="#9CA3AF"
                               VerticalAlignment="Center"
                               Margin="10,0"/>

                    <!-- PASO 3 -->
                    <StackPanel Grid.Column="4"
                                Orientation="Horizontal">

                        <Border x:Name="Step3Circle"
                                Width="55"
                                Height="55"
                                BorderBrush="#9CA3AF"
                                BorderThickness="1.5"
                                Background="Transparent"
                                CornerRadius="28">

                            <TextBlock Text="3"
                                       Foreground="#6B7280"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>

                        </Border>

                        <TextBlock x:Name="Step3Text"
                                   Text="Disponibilidad Horaria"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#667085"
                                   Width="120"
                                   Margin="12,0,0,0"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center"/>

                    </StackPanel>

                </Grid>

                <!-- STEP 1 -->
                <Grid x:Name="Step1Grid"
                      Grid.Row="2">

                    <Border BorderBrush="#B0B0B0"
                            BorderThickness="1"
                            CornerRadius="20"
                            Padding="28"
                            Background="#F7F7F7">

                        <Grid>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="Información básica del docente"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="#1E293B"/>

                            <!-- FORMULARIO -->
                            <Grid Grid.Row="1"
                                  Margin="0,25,0,0">

                                <Grid.Resources>

                                    <Style TargetType="TextBox">
                                        <Setter Property="Height" Value="40"/>
                                        <Setter Property="FontSize" Value="14"/>
                                        <Setter Property="Padding" Value="10,0"/>
                                        <Setter Property="BorderBrush" Value="#A3A3A3"/>
                                        <Setter Property="BorderThickness" Value="1"/>
                                        <Setter Property="Foreground" Value="#9CA3AF"/>
                                    </Style>

                                </Grid.Resources>

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- DOCUMENTO -->
                                <StackPanel Grid.Row="0"
                                            Grid.Column="0"
                                            Margin="0,0,25,18">

                                    <TextBlock FontSize="15"
                                               FontWeight="Bold">
                                        Documento de identidad
                                        <Run Foreground="Red">*</Run>
                                    </TextBlock>

                                    <TextBox Text="1054929981"/>

                                </StackPanel>

                                <!-- TELEFONO -->
                                <StackPanel Grid.Row="0"
                                            Grid.Column="1"
                                            Margin="0,0,25,18">

                                    <TextBlock FontSize="15"
                                               FontWeight="Bold">
                                        Teléfono
                                        <Run Foreground="Red">*</Run>
                                    </TextBlock>

                                    <TextBox Text="3165768610"/>

                                </StackPanel>

                                <!-- HORAS -->
                                <StackPanel Grid.Row="0"
                                            Grid.Column="2">

                                    <TextBlock FontSize="15"
                                               FontWeight="Bold">
                                        Cantidad de horas a dictar
                                        <Run Foreground="Red">*</Run>
                                    </TextBlock>

                                    <TextBox Text="6"/>

                                </StackPanel>

                                <!-- NOMBRES -->
                                <StackPanel Grid.Row="1"
                                            Grid.Column="0"
                                            Margin="0,0,25,18">

                                    <TextBlock FontSize="15"
                                               FontWeight="Bold">
                                        Nombres
                                        <Run Foreground="Red">*</Run>
                                    </TextBlock>

                                    <TextBox Text="Maria Paz"/>

                                </StackPanel>

                                <!-- CORREO -->
                                <StackPanel Grid.Row="1"
                                            Grid.Column="1"
                                            Margin="0,0,25,18">

                                    <TextBlock FontSize="15"
                                               FontWeight="Bold">
                                        Correo
                                        <Run Foreground="Red">*</Run>
                                    </TextBlock>

                                    <TextBox Text="maria@gmail.com"/>

                                </StackPanel>

                                <!-- CONTRATO -->
                                <StackPanel Grid.Row="1"
                                            Grid.Column="2">

                                    <TextBlock FontSize="15"
                                               FontWeight="Bold">
                                        Tipo de contrato
                                        <Run Foreground="Red">*</Run>
                                    </TextBlock>

                                    <ComboBox Height="40"
                                              FontSize="14"
                                              SelectedIndex="0"
                                              Foreground="#6B7280">

                                        <ComboBoxItem Content="Seleccione un tipo de contrato"/>
                                        <ComboBoxItem Content="Tiempo completo"/>
                                        <ComboBoxItem Content="Medio tiempo"/>

                                    </ComboBox>

                                </StackPanel>

                                <!-- APELLIDOS -->
                                <StackPanel Grid.Row="2"
                                            Grid.Column="0"
                                            Margin="0,0,25,0">

                                    <TextBlock FontSize="15"
                                               FontWeight="Bold">
                                        Apellidos
                                        <Run Foreground="Red">*</Run>
                                    </TextBlock>

                                    <TextBox Text="Puerta"/>

                                </StackPanel>

                                <!-- ESTADO -->
                                <StackPanel Grid.Row="2"
                                            Grid.Column="1"
                                            Margin="0,0,25,0">

                                    <TextBlock FontSize="15"
                                               FontWeight="Bold">
                                        Estado
                                        <Run Foreground="Red">*</Run>
                                    </TextBlock>

                                    <ComboBox Height="40"
                                              FontSize="14"
                                              SelectedIndex="0"
                                              Foreground="#6B7280">

                                        <ComboBoxItem Content="Seleccione un estado"/>
                                        <ComboBoxItem Content="Activo"/>
                                        <ComboBoxItem Content="Inactivo"/>

                                    </ComboBox>

                                </StackPanel>

                            </Grid>

                            <!-- FOOTER -->
                            <Grid Grid.Row="2"
                                  Margin="0,35,0,0">

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel>

                                    <TextBlock Text="Tiempo completo: Hasta 40 horas semanales"
                                               FontSize="13"
                                               Foreground="#7B8490"/>

                                    <TextBlock Text="Medio tiempo: Hasta 16 horas semanales"
                                               FontSize="13"
                                               Foreground="#7B8490"
                                               Margin="0,5,0,0"/>

                                </StackPanel>

                                <StackPanel Grid.Column="1"
                                            Orientation="Horizontal">

                                    <Button Content="Cancelar"
                                            Width="150"
                                            Height="45"
                                            FontSize="14"
                                            Margin="0,0,12,0"
                                            Background="White"
                                            BorderBrush="#444"
                                            BorderThickness="1"/>

                                    <Button Width="170"
                                            Height="45"
                                            Background="#16253A"
                                            Foreground="White"
                                            FontSize="14"
                                            FontWeight="SemiBold"
                                            Click="NextButton_Click">

                                        <StackPanel Orientation="Horizontal">

                                            <TextBlock Text="Siguiente"
                                                       Margin="0,0,8,0"/>

                                            <TextBlock Text="→"/>

                                        </StackPanel>

                                    </Button>

                                </StackPanel>

                            </Grid>

                        </Grid>

                    </Border>

                </Grid>

                <!-- STEP 2 -->
                <Grid x:Name="Step2Grid"
      Grid.Row="2"
      Visibility="Collapsed">

                    <Border BorderBrush="#B0B0B0"
            BorderThickness="1"
            CornerRadius="20"
            Padding="28"
            Background="#F7F7F7">

                        <Grid>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- CONTENIDO -->
                            <Grid Margin="0,10,0,0">

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.1*"/>
                                    <ColumnDefinition Width="25"/>
                                    <ColumnDefinition Width="1.6*"/>
                                </Grid.ColumnDefinitions>

                                <!-- IZQUIERDA -->
                                <StackPanel Grid.Column="0">

                                    <TextBlock Text="Especialidades que maneja"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="#1F2937"/>

                                    <TextBlock Text="(Seleccione una o varias)"
                               FontSize="15"
                               Foreground="#6B7280"
                               Margin="0,5,0,25"/>

                                    <CheckBox Content="Matemáticas"
                              FontSize="17"
                              Margin="0,0,0,20"/>

                                    <CheckBox Content="Programación"
                              FontSize="17"
                              Margin="0,0,0,25"
                              IsChecked="True"/>

                                    <TextBlock Text="Otra especialidad"
                               FontSize="15"
                               Foreground="#6B7280"
                               Margin="0,0,0,10"/>

                                    <TextBox Width="280"
                             Height="42"
                             FontSize="15"
                             Padding="10,0"
                             BorderBrush="#9CA3AF"
                             BorderThickness="1"
                             Foreground="#9CA3AF"
                             Text="Especifique otra especialidad..."/>

                                </StackPanel>

                                <!-- LINEA -->
                                <Border Grid.Column="1"
                        Width="1"
                        Background="#D1D5DB"
                        Margin="10,0"/>

                                <!-- DERECHA -->
                                <StackPanel Grid.Column="2">

                                    <TextBlock Text="Materias que puede dictar"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="#1F2937"/>

                                    <TextBlock Text="(Seleccione las materias y el sistema calculará las horas)"
                               FontSize="15"
                               Foreground="#6B7280"
                               Margin="0,5,0,20"/>

                                    <!-- TABLA -->
                                    <Border BorderBrush="#9CA3AF"
                            BorderThickness="1">

                                        <Grid>

                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="55"/>
                                                <RowDefinition Height="65"/>
                                                <RowDefinition Height="65"/>
                                            </Grid.RowDefinitions>

                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="120"/>
                                                <ColumnDefinition Width="140"/>
                                                <ColumnDefinition Width="200"/>
                                                <ColumnDefinition Width="100"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- HEADER -->
                                            <Border Grid.Row="0"
                                    Grid.Column="0"
                                    BorderBrush="#9CA3AF"
                                    BorderThickness="0,0,1,1"
                                    Background="#E5E7EB">

                                                <TextBlock Text="Seleccionar"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>

                                            </Border>

                                            <Border Grid.Row="0"
                                    Grid.Column="1"
                                    BorderBrush="#9CA3AF"
                                    BorderThickness="0,0,1,1"
                                    Background="#E5E7EB">

                                                <TextBlock Text="Código"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>

                                            </Border>

                                            <Border Grid.Row="0"
                                    Grid.Column="2"
                                    BorderBrush="#9CA3AF"
                                    BorderThickness="0,0,1,1"
                                    Background="#E5E7EB">

                                                <TextBlock Text="Materia"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>

                                            </Border>

                                            <Border Grid.Row="0"
                                    Grid.Column="3"
                                    BorderBrush="#9CA3AF"
                                    BorderThickness="0,0,0,1"
                                    Background="#E5E7EB">

                                                <TextBlock Text="Horas"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>

                                            </Border>

                                            <!-- FILA 1 -->
                                            <Border Grid.Row="1"
                                    Grid.Column="0"
                                    BorderBrush="#9CA3AF"
                                    BorderThickness="0,0,1,1">

                                                <CheckBox HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          IsChecked="True"/>

                                            </Border>

                                            <Border Grid.Row="1"
                                    Grid.Column="1"
                                    BorderBrush="#9CA3AF"
                                    BorderThickness="0,0,1,1">

                                                <TextBlock Text="103026"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>

                                            </Border>

                                            <Border Grid.Row="1"
                                    Grid.Column="2"
                                    BorderBrush="#9CA3AF"
                                    BorderThickness="0,0,1,1">

                                                <TextBlock Text="Redes LAN"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>

                                            </Border>

                                            <Border Grid.Row="1"
                                    Grid.Column="3"
                                    BorderBrush="#9CA3AF"
                                    BorderThickness="0,0,0,1">

                                                <TextBlock Text="4"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>

                                            </Border>

                                            <!-- FILA 2 -->
                                            <Border Grid.Row="2"
                                    Grid.Column="0"
                                    BorderBrush="#9CA3AF"
                                    BorderThickness="0,0,1,0">

                                                <CheckBox HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>

                                            </Border>

                                            <Border Grid.Row="2"
                                    Grid.Column="1"
                                    BorderBrush="#9CA3AF"
                                    BorderThickness="0,0,1,0">

                                                <TextBlock Text="104030"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>

                                            </Border>

                                            <Border Grid.Row="2"
                                    Grid.Column="2"
                                    BorderBrush="#9CA3AF"
                                    BorderThickness="0,0,1,0">

                                                <TextBlock Text="Cálculo Diferencial"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>

                                            </Border>

                                            <Border Grid.Row="2"
                                    Grid.Column="3">

                                                <TextBlock Text="4"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>

                                            </Border>

                                        </Grid>

                                    </Border>

                                    <!-- HORAS -->
                                    <TextBlock Margin="0,15,0,0"
                               FontSize="15">

                        <Run Text="Total horas seleccionadas: "
                             Foreground="#6B7280"/>

                        <Run Text="4"
                             Foreground="#15803D"
                             FontWeight="Bold"/>

                        <Run Text=" / "
                             Foreground="#6B7280"/>

                        <Run Text="14"
                             Foreground="#15803D"
                             FontWeight="Bold"/>

                        <Run Text=" horas disponibles"
                             Foreground="#6B7280"/>

                                    </TextBlock>

                                </StackPanel>

                            </Grid>

                            <!-- BOTONES -->
                            <Grid Grid.Row="1"
                  Margin="0,35,0,0">

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Button Width="160"
                        Height="45"
                        FontSize="15"
                        Background="White"
                        BorderBrush="#9CA3AF"
                        BorderThickness="1">

                                    <StackPanel Orientation="Horizontal">

                                        <TextBlock Text="←"
                                   Margin="0,0,10,0"/>

                                        <TextBlock Text="Anterior"/>

                                    </StackPanel>

                                </Button>

                                <StackPanel Grid.Column="1"
                            Orientation="Horizontal">

                                    <Button Content="Cancelar"
                            Width="160"
                            Height="45"
                            FontSize="15"
                            Margin="0,0,15,0"
                            Background="White"
                            BorderBrush="#9CA3AF"
                            BorderThickness="1"/>

                                    <Button Width="170"
                            Height="45"
                            Background="#16253A"
                            Foreground="White"
                            FontSize="15"
                            FontWeight="SemiBold"
                            Click="Step2NextButton_Click">


                                        <StackPanel Orientation="Horizontal">

                                            <TextBlock Text="Siguiente"
                                       Margin="0,0,10,0"/>

                                            <TextBlock Text="→"/>

                                        </StackPanel>

                                    </Button>

                                </StackPanel>

                            </Grid>

                        </Grid>

                    </Border>

                </Grid>

                <!-- STEP 3 -->
                <Grid x:Name="Step3Grid"
      Grid.Row="2"
      Visibility="Collapsed">

                    <Border BorderBrush="#B0B0B0"
            BorderThickness="1"
            CornerRadius="20"
            Padding="28"
            Background="#F7F7F7">

                        <Grid>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- TITULO -->
                            <StackPanel>

                                <TextBlock Text="Disponibilidad Horaria"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="#1E293B"/>

                                <TextBlock Text="Seleccione las horas disponibles por día"
                           FontSize="14"
                           Foreground="#6B7280"
                           Margin="0,5,0,0"/>

                                <!-- LEYENDA -->
                                <StackPanel Orientation="Horizontal"
            Margin="0,15,0,0">

                                    <StackPanel Orientation="Horizontal"
                Margin="0,0,25,0">

                                        <CheckBox IsChecked="True"
                  IsEnabled="False"
                  VerticalAlignment="Center"/>

                                        <TextBlock Text="Disponible"
                   Margin="8,0,0,0"
                   VerticalAlignment="Center"
                   FontSize="13"
                   Foreground="#374151"/>

                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal">

                                        <Border Width="16"
                Height="16"
                BorderBrush="#9CA3AF"
                BorderThickness="1"
                CornerRadius="2"
                VerticalAlignment="Center"/>

                                        <TextBlock Text="No disponible"
                   Margin="8,0,0,0"
                   VerticalAlignment="Center"
                   FontSize="13"
                   Foreground="#374151"/>

                                    </StackPanel>

                                </StackPanel>

                            </StackPanel>
                            
                            

                            <!-- TABLA -->
                            <ScrollViewer Grid.Row="1"
                          Margin="0,25,0,0"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Auto">

                                <Border BorderBrush="#D1D5DB"
                        BorderThickness="1"
                        CornerRadius="10">

                                    <Grid>

                                        <!-- COLUMNAS -->
                                        <Grid.ColumnDefinitions>

                                            <ColumnDefinition Width="100"/>

                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="120"/>

                                        </Grid.ColumnDefinitions>

                                        <!-- FILAS -->
                                        <Grid.RowDefinitions>

                                            <!-- HEADER -->
                                            <RowDefinition Height="45"/>

                                            <!-- 7:00 AM hasta 10:30 PM -->
                                            <RowDefinition Height="40"/>
                                            <RowDefinition Height="40"/>
                                            <RowDefinition Height="40"/>
                                            <RowDefinition Height="40"/>
                                            <RowDefinition Height="40"/>
                                            <RowDefinition Height="40"/>
                                            <RowDefinition Height="40"/>
                                            <RowDefinition Height="40"/>
                                            <RowDefinition Height="40"/>
                                            <RowDefinition Height="40"/>
                                            <RowDefinition Height="40"/>
                                            <RowDefinition Height="40"/>
                                            <RowDefinition Height="40"/>
                                            <RowDefinition Height="40"/>
                                            <RowDefinition Height="40"/>
                                            <RowDefinition Height="40"/>
                                            <RowDefinition Height="40"/>
                                            <RowDefinition Height="40"/>
                                            <RowDefinition Height="40"/>
                                            <RowDefinition Height="40"/>
                                            <RowDefinition Height="40"/>
                                            <RowDefinition Height="40"/>
                                            <RowDefinition Height="40"/>
                                            <RowDefinition Height="40"/>
                                            <RowDefinition Height="40"/>
                                            <RowDefinition Height="40"/>
                                            <RowDefinition Height="40"/>
                                            <RowDefinition Height="40"/>
                                            <RowDefinition Height="40"/>
                                            <RowDefinition Height="40"/>
                                            <RowDefinition Height="40"/>
                                            <RowDefinition Height="40"/>

                                        </Grid.RowDefinitions>

                                        <!-- HEADER -->
                                        <Border Grid.Row="0" Grid.Column="0"
                                Background="#E5E7EB"
                                BorderBrush="#D1D5DB"
                                BorderThickness="0,0,1,1">

                                            <TextBlock Text="Hora"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>

                                        </Border>

                                        <Border Grid.Row="0" Grid.Column="1" Background="#E5E7EB" BorderBrush="#D1D5DB" BorderThickness="0,0,1,1">
                                            <TextBlock Text="Lunes" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>

                                        <Border Grid.Row="0" Grid.Column="2" Background="#E5E7EB" BorderBrush="#D1D5DB" BorderThickness="0,0,1,1">
                                            <TextBlock Text="Martes" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>

                                        <Border Grid.Row="0" Grid.Column="3" Background="#E5E7EB" BorderBrush="#D1D5DB" BorderThickness="0,0,1,1">
                                            <TextBlock Text="Miércoles" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>

                                        <Border Grid.Row="0" Grid.Column="4" Background="#E5E7EB" BorderBrush="#D1D5DB" BorderThickness="0,0,1,1">
                                            <TextBlock Text="Jueves" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>

                                        <Border Grid.Row="0" Grid.Column="5" Background="#E5E7EB" BorderBrush="#D1D5DB" BorderThickness="0,0,1,1">
                                            <TextBlock Text="Viernes" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>

