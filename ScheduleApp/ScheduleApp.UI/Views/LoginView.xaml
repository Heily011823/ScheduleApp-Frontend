<UserControl x:Class="ScheduleApp.UI.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="580"
             Width="1020">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="430"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Image Source="pack://application:,,,/Assets/PanelIzquierdoLogin.png"
                   Stretch="Fill"/>
        </Grid>

        <Grid Grid.Column="1" Background="#F5F5F5">

            <Button x:Name="BtnCerrar"
                    Content="✕"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,15,20,0"
                    Width="30"
                    Height="30"
                    Background="Transparent"
                    BorderThickness="0"
                    FontSize="20"
                    FontWeight="Bold"
                    Foreground="#17333B"
                    Cursor="Hand"
                    Click="BtnCerrar_Click"/>

            <StackPanel Margin="40,60,0,0"
                        Width="360"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top">

                <TextBlock Text="Bienvenido"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="Black"
                           Margin="0,0,0,15"/>

                <TextBlock Text="Completa los campos para continuar"
                           FontSize="18"
                           Foreground="Black"
                           Margin="0,0,0,40"/>

                <TextBlock Text="Usuario o correo institucional"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="Black"
                           Margin="0,0,0,8"/>

                <TextBox x:Name="TxtUsuario"
                         Width="300"
                         Height="38"
                         HorizontalAlignment="Left"
                         FontSize="18"
                         Padding="8,4"
                         BorderThickness="2"
                         BorderBrush="Black"
                         Foreground="Gray"
                         Text="{Binding Usuario, UpdateSourceTrigger=PropertyChanged}"
                         GotFocus="TxtUsuario_GotFocus"
                         LostFocus="TxtUsuario_LostFocus"/>

                <TextBlock Text="Contraseña"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="Black"
                           Margin="0,20,0,8"/>

                <Grid Width="300" Height="38" HorizontalAlignment="Left">
                    <TextBlock x:Name="TxtPlaceholderPassword"
                               Text="Ingresa tu contraseña"
                               Foreground="Gray"
                               FontSize="18"
                               Margin="9,7,0,0"
                               Panel.ZIndex="1"
                               IsHitTestVisible="False"/>
                    <PasswordBox x:Name="TxtContrasena"
                                 FontSize="18"
                                 Padding="8,4"
                                 BorderThickness="2"
                                 BorderBrush="Black"
                                 PasswordChanged="TxtContrasena_PasswordChanged"/>
                </Grid>

                <TextBlock x:Name="LblError"
                           Text="{Binding MensajeError}"
                           Foreground="Red"
                           FontSize="14"
                           Margin="0,10,0,10"
                           TextWrapping="Wrap"
                           FontWeight="SemiBold"/>

                <Button Content="Iniciar sesión"
                        Width="300"
                        Height="42"
                        HorizontalAlignment="Left"
                        FontSize="18"
                        FontWeight="SemiBold"
                        Foreground="White"
                        Background="#17333B"
                        BorderBrush="Black"
                        BorderThickness="2"
                        Cursor="Hand"
                        Margin="0,25,0,0"
                        Command="{Binding LoginCommand}"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>