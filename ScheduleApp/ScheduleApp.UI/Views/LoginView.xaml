<UserControl x:Class="ScheduleApp.UI.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="580"
             Width="1020">

    <Grid Background="White">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="430"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- PANEL IZQUIERDO -->
        <Grid Grid.Column="0">

            <!-- Fondo oscuro -->
            <Border Background="#122033"/>

            <!-- Imagen torre -->

            <!-- Contenido -->
            <Grid>

                <StackPanel VerticalAlignment="Center"
                            HorizontalAlignment="Center">

                    <!-- Logo -->
                    <Image Source="/Assets/Logo.jpeg"
                           Width="200"
                           Height="200"
                           Stretch="Uniform"
                           Margin="0,0,0,10"/>

                    <!-- Titulo -->
                    <TextBlock HorizontalAlignment="Center"
                               FontSize="38"
                               FontWeight="Bold">

                        <Run Text="Schedule"
                             Foreground="White"/>

                        <Run Text="App"
                             Foreground="#D8A43A"/>
                    </TextBlock>

                    <!-- Subtitulo -->
                    <TextBlock Text="SISTEMA DE GESTIÓN DE HORARIO"
                               Foreground="White"
                               FontSize="17"
                               FontWeight="Bold"
                               Margin="0,45,0,0"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- PANEL DERECHO -->
        <Grid Grid.Column="1"
              Background="#F5F5F5">

            <!-- Botón cerrar -->
            <Button Content="X"
                    Width="45"
                    Height="45"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,20,25,0"
                    FontSize="28"
                    Foreground="#0B2340"
                    Background="Transparent"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="BtnCerrar_Click"/>

            <!-- Formulario -->
            <StackPanel Width="390"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Margin="40,70,0,0">

                <!-- Bienvenido -->
                <TextBlock Text="Bienvenido"
                           FontSize="30"
                           FontWeight="Bold"
                           Foreground="Black"
                           Margin="0,0,0,15"/>

                <TextBlock Text="Completa los campos para continuar"
                           FontSize="20"
                           Foreground="Black"
                           Margin="0,0,0,40"/>

                <!-- Usuario -->
                <TextBlock Text="Usuario o correo institucional"
                           FontSize="17"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8"/>

                <TextBox x:Name="TxtUsuario"
                         Width="320"
                         Height="38"
                         FontSize="18"
                         Padding="10,4"
                         BorderThickness="2"
                         BorderBrush="Black"
                         Foreground="Gray"
                         Text="Ingresa tu usuario o correo"
                         GotFocus="TxtUsuario_GotFocus"
                         LostFocus="TxtUsuario_LostFocus"/>

                <!-- Contraseña -->
                <TextBlock Text="Contraseña"
                           FontSize="17"
                           FontWeight="SemiBold"
                           Margin="0,22,0,8"/>

                <Grid Width="320"
                      Height="38">

                    <!-- Password -->
                    <PasswordBox x:Name="TxtContrasena"
                                 FontSize="18"
                                 Padding="10,4"
                                 BorderThickness="2"
                                 BorderBrush="Black"
                                 PasswordChanged="TxtContrasena_PasswordChanged"/>

                    <!-- Placeholder -->
                    <TextBlock x:Name="TxtPlaceholderPassword"
                               Text="Ingresa tu contraseña"
                               Foreground="Gray"
                               FontSize="18"
                               Margin="12,7,0,0"
                               Panel.ZIndex="1"
                               IsHitTestVisible="False"/>
                </Grid>

                <!-- Error -->
                <TextBlock x:Name="LblError"
                           Foreground="Red"
                           FontSize="14"
                           Margin="0,10,0,20"
                           TextWrapping="Wrap"/>

                <!-- Botón login -->
                <Button Content="Iniciar sesión"
                        Width="320"
                        Height="42"
                        FontSize="19"
                        FontWeight="SemiBold"
                        Foreground="White"
                        Background="#17333B"
                        BorderBrush="Black"
                        BorderThickness="2"
                        Cursor="Hand"
                        Margin="0,25,0,0"
                        Click="BtnLogin_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>