<UserControl x:Class="ScheduleApp.UI.Views.DeleteUserView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="White">

        <TextBlock Text="Eliminar usuario"
                   FontSize="30"
                   FontWeight="Bold"
                   Foreground="Black"
                   Margin="25,45,0,0"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Top"/>

        <Border Width="760"
                Height="350"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                BorderBrush="#1B2A41"
                BorderThickness="1"
                CornerRadius="25"
                Background="White">

            <Grid Margin="60,35,60,35">

                <TextBlock Text="¿Está seguro?"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="#0B132A"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Top"/>

                <TextBlock Text="Si está seguro de eliminar este usuario escriba la palabra “Borrar” en el espacio dado."
                           FontSize="20"
                           Foreground="#333333"
                           TextWrapping="Wrap"
                           Margin="0,70,0,0"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Top"/>

                <TextBox Height="42"
                         FontSize="18"
                         Padding="10,0"
                         VerticalContentAlignment="Center"
                         Margin="0,145,0,0"
                         VerticalAlignment="Top"
                         Text="{Binding ConfirmationText, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="Red"
                           FontSize="14"
                           FontWeight="SemiBold"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Bottom"
                           Margin="0,0,0,78"/>

                <Button Content="Cancelar"
                        Width="200"
                        Height="48"
                        FontSize="20"
                        Background="White"
                        Foreground="Black"
                        BorderBrush="Black"
                        BorderThickness="1"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Bottom"
                        Margin="65,0,0,0"
                        Command="{Binding CancelCommand}"/>

                <Button Content="Confirmar"
                        Width="200"
                        Height="48"
                        FontSize="20"
                        FontWeight="Bold"
                        Background="#1B2A41"
                        Foreground="White"
                        BorderBrush="Black"
                        BorderThickness="2"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Margin="0,0,65,0"
                        Command="{Binding ConfirmDeleteCommand}"/>

            </Grid>
        </Border>
    </Grid>
</UserControl>