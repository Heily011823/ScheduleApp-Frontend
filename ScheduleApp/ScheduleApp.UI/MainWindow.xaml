<Window x:Class="ScheduleApp.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ScheduleApp - Dashboard" Height="600" Width="1080"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Background="#17333B">
            <Button Content="Inicio" Height="40" Margin="10,20,10,10"/>
            <Button Content="Materias" Height="40" Margin="10,10,10,10"/>
        </StackPanel>

        <Grid Grid.Column="1" Background="White">
            <TextBlock Text="¡Bienvenido al Sistema de Gestión de Horarios!" 
                       HorizontalAlignment="Center" 
                       VerticalAlignment="Center" 
                       FontSize="24" 
                       Foreground="Gray"/>
        </Grid>
    </Grid>
</Window>